generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String      @id @default(uuid()) @db.Uuid
  transactionDate  DateTime    @default(now()) @map("transaction_date") @db.Timestamp(6)
  startDate        DateTime?   @map("start_date") @db.Timestamp(6)
  endDate          DateTime?   @map("end_date") @db.Timestamp(6)
  createdBy        String?     @map("created_by") @db.VarChar(100)
  updatedBy        String?     @map("updated_by") @db.VarChar(100)
  createdAt        DateTime    @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt        DateTime    @updatedAt @map("updated_at") @db.Timestamp(6)
  fullName         String      @map("full_name") @db.VarChar(120)
  email            String      @unique @db.VarChar(120)
  passwordHash     String      @map("password_hash") @db.VarChar(255)
  active           Boolean     @default(true)
  userRoles        UserRole[]
  inscriptions     Inscription[]

  @@map("users")
}

model Role {
  id              String          @id @default(uuid()) @db.Uuid
  transactionDate DateTime        @default(now()) @map("transaction_date") @db.Timestamp(6)
  startDate       DateTime?       @map("start_date") @db.Timestamp(6)
  endDate         DateTime?       @map("end_date") @db.Timestamp(6)
  createdBy       String?         @map("created_by") @db.VarChar(100)
  updatedBy       String?         @map("updated_by") @db.VarChar(100)
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime        @updatedAt @map("updated_at") @db.Timestamp(6)
  name            String          @unique @db.VarChar(120)
  active          Boolean         @default(true)
  rolePrivileges  RolePrivilege[]
  userRoles       UserRole[]

  @@map("roles")
}

model Privilege {
  id              String          @id @default(uuid()) @db.Uuid
  transactionDate DateTime        @default(now()) @map("transaction_date") @db.Timestamp(6)
  startDate       DateTime?       @map("start_date") @db.Timestamp(6)
  endDate         DateTime?       @map("end_date") @db.Timestamp(6)
  createdBy       String?         @map("created_by") @db.VarChar(100)
  updatedBy       String?         @map("updated_by") @db.VarChar(100)
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime        @updatedAt @map("updated_at") @db.Timestamp(6)
  code            String          @unique @db.VarChar(160)
  action          String          @db.VarChar(50)
  moduleId        String          @map("module_id") @db.Uuid
  module          SystemModule    @relation(fields: [moduleId], references: [id])
  rolePrivileges  RolePrivilege[]

  @@map("privileges")
}

model SystemModule {
  id              String        @id @default(uuid()) @db.Uuid
  transactionDate DateTime      @default(now()) @map("transaction_date") @db.Timestamp(6)
  startDate       DateTime?     @map("start_date") @db.Timestamp(6)
  endDate         DateTime?     @map("end_date") @db.Timestamp(6)
  createdBy       String?       @map("created_by") @db.VarChar(100)
  updatedBy       String?       @map("updated_by") @db.VarChar(100)
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamp(6)
  key             String        @unique @db.VarChar(100)
  name            String        @db.VarChar(120)
  privileges      Privilege[]

  @@map("system_modules")
}

model UserRole {
  id              String      @id @default(uuid()) @db.Uuid
  transactionDate DateTime    @default(now()) @map("transaction_date") @db.Timestamp(6)
  startDate       DateTime?   @map("start_date") @db.Timestamp(6)
  endDate         DateTime?   @map("end_date") @db.Timestamp(6)
  createdBy       String?     @map("created_by") @db.VarChar(100)
  updatedBy       String?     @map("updated_by") @db.VarChar(100)
  createdAt       DateTime    @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime    @updatedAt @map("updated_at") @db.Timestamp(6)
  userId          String      @map("user_id") @db.Uuid
  roleId          String      @map("role_id") @db.Uuid
  user            User        @relation(fields: [userId], references: [id])
  role            Role        @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
  @@map("user_roles")
}

model RolePrivilege {
  id              String      @id @default(uuid()) @db.Uuid
  transactionDate DateTime    @default(now()) @map("transaction_date") @db.Timestamp(6)
  startDate       DateTime?   @map("start_date") @db.Timestamp(6)
  endDate         DateTime?   @map("end_date") @db.Timestamp(6)
  createdBy       String?     @map("created_by") @db.VarChar(100)
  updatedBy       String?     @map("updated_by") @db.VarChar(100)
  createdAt       DateTime    @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime    @updatedAt @map("updated_at") @db.Timestamp(6)
  roleId          String      @map("role_id") @db.Uuid
  privilegeId     String      @map("privilege_id") @db.Uuid
  role            Role        @relation(fields: [roleId], references: [id])
  privilege       Privilege   @relation(fields: [privilegeId], references: [id])

  @@unique([roleId, privilegeId])
  @@map("role_privileges")
}

model Course {
  id              String       @id @default(uuid()) @db.Uuid
  transactionDate DateTime     @default(now()) @map("transaction_date") @db.Timestamp(6)
  startDate       DateTime?    @map("start_date") @db.Timestamp(6)
  endDate         DateTime?    @map("end_date") @db.Timestamp(6)
  createdBy       String?      @map("created_by") @db.VarChar(100)
  updatedBy       String?      @map("updated_by") @db.VarChar(100)
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime     @updatedAt @map("updated_at") @db.Timestamp(6)
  title           String       @db.VarChar(140)
  description     String       @db.Text
  status          String       @default("draft") @db.VarChar(20)
  level           String       @default("basic") @db.VarChar(40)
  lessons         Lesson[]
  inscriptions    Inscription[]
  evaluations     Evaluation[]

  @@map("courses")
}

model Lesson {
  id              String       @id @default(uuid()) @db.Uuid
  transactionDate DateTime     @default(now()) @map("transaction_date") @db.Timestamp(6)
  startDate       DateTime?    @map("start_date") @db.Timestamp(6)
  endDate         DateTime?    @map("end_date") @db.Timestamp(6)
  createdBy       String?      @map("created_by") @db.VarChar(100)
  updatedBy       String?      @map("updated_by") @db.VarChar(100)
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime     @updatedAt @map("updated_at") @db.Timestamp(6)
  title           String       @db.VarChar(140)
  content         String       @db.Text
  contentType     String       @default("text") @map("content_type") @db.VarChar(20)
  courseId        String       @map("course_id") @db.Uuid
  course          Course       @relation(fields: [courseId], references: [id])
  califications   Calification[]

  @@map("lessons")
}

model Inscription {
  id                  String         @id @default(uuid()) @db.Uuid
  transactionDate     DateTime       @default(now()) @map("transaction_date") @db.Timestamp(6)
  startDate           DateTime?      @map("start_date") @db.Timestamp(6)
  endDate             DateTime?      @map("end_date") @db.Timestamp(6)
  createdBy           String?        @map("created_by") @db.VarChar(100)
  updatedBy           String?        @map("updated_by") @db.VarChar(100)
  createdAt           DateTime       @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt           DateTime       @updatedAt @map("updated_at") @db.Timestamp(6)
  userId              String         @map("user_id") @db.Uuid
  courseId            String         @map("course_id") @db.Uuid
  user                User           @relation(fields: [userId], references: [id])
  course              Course         @relation(fields: [courseId], references: [id])
  status              String         @default("enrolled") @db.VarChar(20)
  progressPercentage  Decimal?       @map("progress_percentage") @db.Decimal(5, 2)
  completedAt         DateTime?      @map("completed_at") @db.Timestamp(6)
  progress            Progress[]
  certificates        Certificate[]

  @@map("inscriptions")
}

model Progress {
  id                  String       @id @default(uuid()) @db.Uuid
  transactionDate     DateTime     @default(now()) @map("transaction_date") @db.Timestamp(6)
  startDate           DateTime?    @map("start_date") @db.Timestamp(6)
  endDate             DateTime?    @map("end_date") @db.Timestamp(6)
  createdBy           String?      @map("created_by") @db.VarChar(100)
  updatedBy           String?      @map("updated_by") @db.VarChar(100)
  createdAt           DateTime     @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt           DateTime     @updatedAt @map("updated_at") @db.Timestamp(6)
  inscriptionId       String       @map("inscription_id") @db.Uuid
  inscription         Inscription  @relation(fields: [inscriptionId], references: [id])
  lessonsCompleted    Decimal      @default(0) @map("lessons_completed") @db.Decimal(5, 2)
  evaluationsCompleted Decimal     @default(0) @map("evaluations_completed") @db.Decimal(5, 2)
  averageScore        Decimal      @default(0) @map("average_score") @db.Decimal(5, 2)
  progressPercentage  Decimal      @default(0) @map("progress_percentage") @db.Decimal(5, 2)
  lastAccessAt        DateTime?    @map("last_access_at") @db.Timestamp(6)

  @@map("progress")
}

model Certificate {
  id                  String       @id @default(uuid()) @db.Uuid
  transactionDate     DateTime     @default(now()) @map("transaction_date") @db.Timestamp(6)
  startDate           DateTime?    @map("start_date") @db.Timestamp(6)
  endDate             DateTime?    @map("end_date") @db.Timestamp(6)
  createdBy           String?      @map("created_by") @db.VarChar(100)
  updatedBy           String?      @map("updated_by") @db.VarChar(100)
  createdAt           DateTime     @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt           DateTime     @updatedAt @map("updated_at") @db.Timestamp(6)
  inscriptionId       String       @map("inscription_id") @db.Uuid
  inscription         Inscription  @relation(fields: [inscriptionId], references: [id])
  certificateNumber    String       @unique @map("certificate_number") @db.VarChar(100)
  issuedAt            DateTime     @map("issued_at") @db.Timestamp(6)
  expiresAt           DateTime?    @map("expires_at") @db.Timestamp(6)
  status              String       @default("valid") @db.VarChar(20)
  pdfUrl              String?      @map("pdf_url") @db.Text

  @@map("certificates")
}

model AuditLog {
  id                String    @id @default(uuid()) @db.Uuid
  transactionDate   DateTime  @default(now()) @map("transaction_date") @db.Timestamp(6)
  startDate         DateTime? @map("start_date") @db.Timestamp(6)
  endDate           DateTime? @map("end_date") @db.Timestamp(6)
  createdBy         String?   @map("created_by") @db.VarChar(100)
  updatedBy         String?   @map("updated_by") @db.VarChar(100)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)
  method            String    @db.VarChar(12)
  endpoint          String    @db.VarChar(255)
  transactionType   String    @map("transaction_type") @db.VarChar(30)
  actorScope        String    @default("anonymous") @map("actor_scope") @db.VarChar(20)
  actorIdentifier   String?   @map("actor_identifier") @db.VarChar(140)
  browser           String?   @db.VarChar(150)
  description       String    @db.Text
  statusCode        Int?      @map("status_code")

  @@map("audit_logs")
}

model Calification {
  id              String    @id @default(uuid()) @db.Uuid
  transactionDate DateTime  @default(now()) @map("transaction_date") @db.Timestamp(6)
  startDate       DateTime? @map("start_date") @db.Timestamp(6)
  endDate         DateTime? @map("end_date") @db.Timestamp(6)
  createdBy       String?   @map("created_by") @db.VarChar(100)
  updatedBy       String?   @map("updated_by") @db.VarChar(100)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)
  title           String    @db.VarChar(140)
  content         String    @db.Text
  type            String    @default("quiz") @db.VarChar(20)
  totalPoints     Int       @default(10) @map("total_points")
  maxAttempts     Int       @default(1) @map("max_attempts")
  lessonId        String    @map("lesson_id") @db.Uuid
  lesson          Lesson    @relation(fields: [lessonId], references: [id])

  @@map("califications")
}

model Evaluation {
  id              String    @id @default(uuid()) @db.Uuid
  transactionDate DateTime  @default(now()) @map("transaction_date") @db.Timestamp(6)
  startDate       DateTime? @map("start_date") @db.Timestamp(6)
  endDate         DateTime? @map("end_date") @db.Timestamp(6)
  createdBy       String?   @map("created_by") @db.VarChar(100)
  updatedBy       String?   @map("updated_by") @db.VarChar(100)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)
  title           String    @db.VarChar(140)
  description     String?   @db.Text
  courseId        String    @map("course_id") @db.Uuid
  course          Course    @relation(fields: [courseId], references: [id])
  attempts        EvaluationAttempt[]

  @@map("evaluations")
}

model EvaluationAttempt {
  id              String    @id @default(uuid()) @db.Uuid
  transactionDate DateTime  @default(now()) @map("transaction_date") @db.Timestamp(6)
  startDate       DateTime? @map("start_date") @db.Timestamp(6)
  endDate         DateTime? @map("end_date") @db.Timestamp(6)
  createdBy       String?   @map("created_by") @db.VarChar(100)
  updatedBy       String?   @map("updated_by") @db.VarChar(100)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)
  evaluationId    String    @map("evaluation_id") @db.Uuid
  evaluation      Evaluation @relation(fields: [evaluationId], references: [id])
  studentId       String    @map("student_id") @db.Uuid
  answers         Json
  score           Decimal?  @map("score") @db.Decimal(5,2)

  @@map("evaluation_attempts")
}
